<?xml version="1.0" encoding="utf-8"?>
<mujoco model="anymal">
  <compiler angle="radian" meshdir="assets" autolimits="true"/>

  <option cone="elliptic" impratio="100"/>

  <default>
    <default class="anymal">
      <geom friction="0.8" margin="0.001" condim="1"/>
      <joint damping="2" armature="0.01" frictionloss="0.2"/>
      <motor ctrlrange="-80 80" ctrllimited="true"/>

      <default class="haa">
        <joint axis="1 0 0"/>
      </default>

      <default class="hfe">
        <joint axis="1 0 0" range="-9.42477796077 9.42477796077"/>
      </default>

      <default class="kfe">
        <joint axis="1 0 0" range="-9.42477796077 9.42477796077"/>
      </default>

      <default class="foot">
        <site group="1"/>
        <geom rgba="0.2 0.2 0.2 1"/>
      </default>

      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>

      <default class="collision">
        <geom group="3"/>
        <default class="foot_collision">
          <geom size="0.03" priority="1" solimp="0.015 1 0.031" condim="6" friction="0.8 0.02 0.01"/>
        </default>
      </default>
    </default>
  </default>

  <asset>
    <material name="metal" rgba="0.7 0.7 0.75 1"/>
