    <material name="gray" rgba="0.5 0.5 0.5 1"/>
    <material name="orange" rgba="1 0.5 0 1"/>

    <!-- Mesh files - these should be in the assets directory -->
    <mesh file="base.stl"/>
    <mesh file="top_shell.stl"/>
    <mesh file="bottom_shell.stl"/>
    <mesh file="remote.stl"/>
    <mesh file="handle.stl"/>
    <mesh file="face.stl"/>
    <mesh file="battery.stl"/>
    <mesh file="drive.stl"/>
    <mesh file="hip_l.stl"/>
    <mesh file="hip_r.stl"/>
