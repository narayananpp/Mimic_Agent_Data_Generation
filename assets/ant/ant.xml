<mujoco model="ant">
  <compiler angle="radian"/>

  <default>
    <motor ctrlrange="-1 1" ctrllimited="true"/>
    <default class="body">
      <geom condim="1" friction="1.0 0.05 0.05" solimp=".9 .99 .003" solref=".015 1"/>
      <joint limited="true" solimplimit="0 .99 .01"/>
    </default>
  </default>

  <worldbody>
    <body name="torso" pos="0 0 0.75" childclass="body">
      <freejoint name="root"/>
      <geom name="torso" type="sphere" size="0.25" density="1000"/>

      <!-- Front-Right Leg -->
      <body name="front_right_hip" pos="0.2 -0.2 0">
        <joint name="front_right_hip_x" type="hinge" axis="1 0 0" range="-0.5236 0.5236"
               actuatorfrcrange="-150 150" stiffness="400" damping="40" armature=".02"/>
        <joint name="front_right_hip_y" type="hinge" axis="0 1 0" range="-0.5236 0.5236"
               actuatorfrcrange="-150 150" stiffness="400" damping="40" armature=".02"/>
        <geom name="front_right_hip" type="capsule" fromto="0 0 0 0.14 -0.14 0" size="0.08" density="1000"/>

        <body name="front_right_ankle" pos="0.14 -0.14 0">
          <joint name="front_right_ankle" type="hinge" axis="0 1 0" range="0.5236 1.9199"
                 actuatorfrcrange="-150 150" stiffness="400" damping="40" armature=".02"/>
          <geom name="front_right_ankle" type="capsule" fromto="0 0 0 0.24 -0.24 0" size="0.08" density="1000"/>
        </body>
      </body>

      <!-- Front-Left Leg -->
      <body name="front_left_hip" pos="0.2 0.2 0">
        <joint name="front_left_hip_x" type="hinge" axis="1 0 0" range="-0.5236 0.5236"
               actuatorfrcrange="-150 150" stiffness="400" damping="40" armature=".02"/>
        <joint name="front_left_hip_y" type="hinge" axis="0 1 0" range="-0.5236 0.5236"
               actuatorfrcrange="-150 150" stiffness="400" damping="40" armature=".02"/>
        <geom name="front_left_hip" type="capsule" fromto="0 0 0 0.14 0.14 0" size="0.08" density="1000"/>

        <body name="front_left_ankle" pos="0.14 0.14 0">
          <joint name="front_left_ankle" type="hinge" axis="0 1 0" range="0.5236 1.9199"
                 actuatorfrcrange="-150 150" stiffness="400" damping="40" armature=".02"/>
          <geom name="front_left_ankle" type="capsule" fromto="0 0 0 0.24 0.24 0" size="0.08" density="1000"/>
        </body>
      </body>

      <!-- Back-Right Leg -->
      <body name="back_right_hip" pos="-0.2 -0.2 0">
        <joint name="back_right_hip_x" type="hinge" axis="1 0 0" range="-0.5236 0.5236"
               actuatorfrcrange="-150 150" stiffness="400" damping="40" armature=".02"/>
        <joint name="back_right_hip_y" type="hinge" axis="0 1 0" range="-0.5236 0.5236"
               actuatorfrcrange="-150 150" stiffness="400" damping="40" armature=".02"/>
        <geom name="back_right_hip" type="capsule" fromto="0 0 0 -0.14 -0.14 0" size="0.08" density="1000"/>

        <body name="back_right_ankle" pos="-0.14 -0.14 0">
          <joint name="back_right_ankle" type="hinge" axis="0 1 0" range="0.5236 1.9199"
                 actuatorfrcrange="-150 150" stiffness="400" damping="40" armature=".02"/>
          <geom name="back_right_ankle" type="capsule" fromto="0 0 0 -0.24 -0.24 0" size="0.08" density="1000"/>
        </body>
      </body>

      <!-- Back-Left Leg -->
      <body name="back_left_hip" pos="-0.2 0.2 0">
        <joint name="back_left_hip_x" type="hinge" axis="1 0 0" range="-0.5236 0.5236"
               actuatorfrcrange="-150 150" stiffness="400" damping="40" armature=".02"/>
        <joint name="back_left_hip_y" type="hinge" axis="0 1 0" range="-0.5236 0.5236"
               actuatorfrcrange="-150 150" stiffness="400" damping="40" armature=".02"/>
        <geom name="back_left_hip" type="capsule" fromto="0 0 0 -0.14 0.14 0" size="0.08" density="1000"/>

        <body name="back_left_ankle" pos="-0.14 0.14 0">
          <joint name="back_left_ankle" type="hinge" axis="0 1 0" range="0.5236 1.9199"
                 actuatorfrcrange="-150 150" stiffness="400" damping="40" armature=".02"/>
          <geom name="back_left_ankle" type="capsule" fromto="0 0 0 -0.24 0.24 0" size="0.08" density="1000"/>
        </body>
      </body>

    </body>
  </worldbody>

  <actuator>
    <!-- Front-Right -->
    <motor name="front_right_hip_x"  gear="150" joint="front_right_hip_x"/>
    <motor name="front_right_hip_y"  gear="150" joint="front_right_hip_y"/>
    <motor name="front_right_ankle"  gear="150" joint="front_right_ankle"/>

    <!-- Front-Left -->
    <motor name="front_left_hip_x"   gear="150" joint="front_left_hip_x"/>
    <motor name="front_left_hip_y"   gear="150" joint="front_left_hip_y"/>
    <motor name="front_left_ankle"   gear="150" joint="front_left_ankle"/>

    <!-- Back-Right -->
    <motor name="back_right_hip_x"   gear="150" joint="back_right_hip_x"/>
    <motor name="back_right_hip_y"   gear="150" joint="back_right_hip_y"/>
    <motor name="back_right_ankle"   gear="150" joint="back_right_ankle"/>

    <!-- Back-Left -->
    <motor name="back_left_hip_x"    gear="150" joint="back_left_hip_x"/>
    <motor name="back_left_hip_y"    gear="150" joint="back_left_hip_y"/>
    <motor name="back_left_ankle"    gear="150" joint="back_left_ankle"/>
  </actuator>

</mujoco>